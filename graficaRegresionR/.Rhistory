library(ggrepel)   # Para evitar solapamiento de etiquetas en el gráfico
library(broom)     # Para convertir modelos estadísticos en data frames ordenados
# 2. CARGA Y UNIÓN DE DATOS
# ----------------------------------------------------
# Nombres de los ficheros de entrada
fichero_observado <- "datosEntrada/cobertura_compas_25-05-22.csv"
fichero_calculado <- "datosEntrada/20250907-2011_ENDVI_sin_sombras_reclasificado.csv"
# Leer los datos
datos_observados <- read_csv(fichero_observado)
datos_calculados <- read_csv(fichero_calculado)
# Eliminar la columna 'COB_TOTAL' del dataframe 'datos_calculados', si existe.
if("COB_TOTAL" %in% names(datos_calculados)) {
datos_calculados <- select(datos_calculados, -COB_TOTAL)
cat("Se ha eliminado la columna 'COB_TOTAL' del fichero de datos calculados.\n")
}
print(datos_observados)
print(datos_calculados)
# Unir las dos tablas usando la columna en común 'ID_QUADRAT'
# Se usará un inner_join para mantener solo las filas que estén en ambos ficheros
datos_unidos <- inner_join(datos_observados, datos_calculados, by = "ID_QUADRAT")
print(datos_unidos)
# 3. ANÁLISIS DE REGRESIÓN Y CÁLCULO DE MÉTRICAS
# ----------------------------------------------------
# Se agrupan los datos por la columna 'tratamientos' y se aplica un modelo lineal
# a cada grupo. broom::glance() extrae las métricas de cada modelo (R^2, etc.)
metricas_regresion <- datos_unidos %>%
nest_by(tratamientos_quema_primavera) %>%  # 1. Agrupa y "anida" los datos para cada tratamiento
mutate(modelo = list(lm(COB_TOTAL ~ cobertura_calculada, data = data))) %>%  # 2. Crea el modelo para cada set de datos anidado
summarise(glance(modelo)) %>%  # 3. Aplica glance a cada modelo y extrae las métricas
ungroup() %>%  # 4. Desagrupa el resultado final
select(  # 5. Seleccionamos y renombramos las métricas de interés (como ya tenías)
tratamientos,
r.squared,
r2_ajustado = adj.r.squared,
rmse = sigma,
p_valor = p.value
)
# 3. ANÁLISIS DE REGRESIÓN Y CÁLCULO DE MÉTRICAS
# ----------------------------------------------------
# Se agrupan los datos por la columna 'tratamientos' y se aplica un modelo lineal
# a cada grupo. broom::glance() extrae las métricas de cada modelo (R^2, etc.)
metricas_regresion <- datos_unidos %>%
nest_by(tratamientos_quema_primavera) %>%  # 1. Agrupa y "anida" los datos para cada tratamiento
mutate(modelo = list(lm(COB_TOTAL ~ cobertura_calculada, data = data))) %>%  # 2. Crea el modelo para cada set de datos anidado
summarise(glance(modelo)) %>%  # 3. Aplica glance a cada modelo y extrae las métricas
ungroup() %>%  # 4. Desagrupa el resultado final
select(  # 5. Seleccionamos y renombramos las métricas de interés (como ya tenías)
tratamientos_quema_primavera,
r.squared,
r2_ajustado = adj.r.squared,
rmse = sigma,
p_valor = p.value
)
# Mostramos las métricas por consola
print("Métricas de la regresión por tratamiento:")
print(as.data.frame(metricas_regresion))
# 4. CREACIÓN DEL GRÁFICO CON GGPLOT2
# ----------------------------------------------------
# Preparamos las etiquetas de texto con las métricas para añadirlas al gráfico
etiquetas_metricas <- metricas_regresion %>%
mutate(
etiqueta = paste0(
"R² = ", round(r.squared, 2), "\n",
"RMSE = ", round(rmse, 2), "%"
)
)
# Unimos las etiquetas al data frame principal para usarlas en el gráfico
datos_grafico <- left_join(datos_unidos, etiquetas_metricas, by = "tratamientos")
# Unimos las etiquetas al data frame principal para usarlas en el gráfico
datos_grafico <- left_join(datos_unidos, etiquetas_metricas, by = "tratamientos_quema_primavera")
# Creamos el gráfico
grafico_regresion <- ggplot(datos_grafico, aes(x = cobertura_calculada, y = COB_TOTAL, color = tratamientos)) +
# Nube de puntos
geom_point(alpha = 0.8, size = 2) +
# Línea de regresión lineal (lm) con intervalo de confianza del 95%
geom_smooth(method = "lm", se = TRUE, aes(fill = tratamientos), alpha = 0.1) +
# Etiquetas de texto para cada punto (ID_QUADRAT), con ggrepel para evitar solapamientos
geom_text_repel(aes(label = ID_QUADRAT), size = 3, show.legend = FALSE) +
# Añadimos las métricas R² y RMSE en cada subplot
geom_text(
aes(x = -Inf, y = Inf, label = etiqueta),
hjust = -0.1, # Justificación horizontal (cerca del borde izquierdo)
vjust = 1.5,  # Justificación vertical (debajo del borde superior)
size = 4,
check_overlap = TRUE # Evita que se escriban una encima de otra
) +
# Separamos el gráfico en facetas o subplots, uno por cada 'tratamiento'
facet_wrap(~ tratamientos, scales = "free") +
# Definimos los títulos, etiquetas y tema del gráfico
labs(
title = "Regresión Lineal: Cobertura Observada vs. Calculada",
subtitle = "Agrupado por tipo de tratamiento",
x = "Cobertura Calculada (%)",
y = "Cobertura Observada (COB_TOTAL, %)",
color = "Tratamiento",
fill = "Intervalo de Confianza 95%"
) +
theme_minimal() + # Un tema limpio para el gráfico
theme(legend.position = "bottom") # Posición de la leyenda
# Mostramos el gráfico
print(grafico_regresion)
# 5. GUARDADO DE RESULTADOS
# ----------------------------------------------------
# Guardamos el gráfico en un fichero PNG
ggsave("grafico_regresion_R.png", plot = grafico_regresion, width = 12, height = 8, dpi = 300)
# Guardamos las métricas en un fichero CSV
write_csv(metricas_regresion, "metricas_regresion_R.csv")
